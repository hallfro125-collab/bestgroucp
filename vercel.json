{
  "installCommand": "npm install -g pnpm@10 && pnpm install",
  "buildCommand": "pnpm --filter @workspace/vip-landing run build",
  "outputDirectory": "artifacts/vip-landing/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,x-admin-token" }
      ]
    }
  ]
}
